# Frontend environment variables
# Copy this file to .env in this directory (src/frontend) and set your values if needed.
# By default, Vite proxies /api and /health to http://localhost:5000 automatically (no changes needed for local dev).

# API base URL — leave empty for local dev (Vite proxy in vite.config.ts handles routing).
# Set to the full backend URL ONLY if running frontend and backend on different ports/hosts.
VITE_API_BASE_URL=http://localhost:5000

# Set to "true" ONLY in local development if you need to persist the JWT token in localStorage.
# WARNING: this is a security risk — do NOT enable in production.
VITE_ALLOW_INSECURE_TOKEN_STORAGE=false
