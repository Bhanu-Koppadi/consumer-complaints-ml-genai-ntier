# Backend environment configuration
# Copy this file to .env in this directory (src/backend) and set your values.
# Do not commit .env; it is listed in .gitignore.

# Database (default matches infra/docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consumer_complaints

# GenAI (optional — omit for mock explanations)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ML model paths (relative to src/backend)
ML_MODEL_PATH=models/complaint_classifier.pkl
VECTORIZER_PATH=models/tfidf_vectorizer.pkl
USE_TRANSFORMER_MODEL=false

# Application security (REQUIRED in production — use strong random values)
# JWT_SECRET_KEY must be at least 32 bytes (256 bits) to avoid HMAC key-length warnings.
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-in-production

# Default users (development only — set CREATE_DEFAULT_USERS=true for initial setup)
# Creates admin and user if they do not exist. Leave false in production.
CREATE_DEFAULT_USERS=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_EMAIL=admin@localhost
DEFAULT_USER_USERNAME=user
DEFAULT_USER_PASSWORD=User@123
DEFAULT_USER_EMAIL=user@localhost

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Flask
FLASK_APP=app.py
FLASK_DEBUG=0

# Email delivery mode: "simulate" (default, no real email sent) or "smtp" (real email)
# For demo/presentation use "simulate". Switch to "smtp" for production.
EMAIL_DELIVERY_MODE=simulate

# SMTP credentials (only required when EMAIL_DELIVERY_MODE=smtp)
# Example below uses Gmail App Password — see: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Consumer Complaints System
